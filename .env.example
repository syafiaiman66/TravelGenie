DATABASE_URL=postgresql://username:password@host:5432/database_name?sslmode=require
DATA_ENCRYPTION_SECRET=generate_a_long_random_secret

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback

GEMINI_API_KEY=your_ai_api_key
GEMINI_MODEL=gemini-2.5-flash

# Feedback is currently sent with Web3Forms from app.js.
# SMTP settings are optional only if you later re-enable /api/feedback.
FEEDBACK_TO=bouncebtoe@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

COOKIE_SECURE=false
HOST=127.0.0.1